+            width  = shm_.size.x;
+            height = shm_.size.y;
+            stride = shm_.stride;
+            drmFmt = shm_.format;
+        }
+
+        if (width <= 0 || height <= 0) {
+            backend->backend->log(AQ_LOG_ERROR, "WaylandBuffer SHM: cannot determine buffer dimensions");
+            return;
+        }
+
+        if (stride <= 0)
+            stride = width * 4;
+
