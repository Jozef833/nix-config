+        auto dma  = buffer->dmabuf();
+        auto shm_ = buffer->shm();
+
+        int width = 0, height = 0, stride = 0;
+        uint32_t drmFmt = DRM_FORMAT_ARGB8888;
+
+        if (dma.success) {
+            width  = dma.size.x;
+            height = dma.size.y;
+            stride = dma.strides.at(0);
