+void CRenderbuffer::readbackIfStandalone() {
+    if (!m_standalone)
+        return;
+
+    auto buf = m_hlBuffer.lock();
+    if (!buf)
+        return;
+
+    auto [pixelData, fmt, bufLen] = buf->beginDataPtr(0);
+    if (!pixelData || bufLen == 0)
+        return;
+
+    const int w      = (int)m_framebuffer.m_size.x;
+    const int h      = (int)m_framebuffer.m_size.y;
+    const int stride = buf->dmabuf().strides[0]; // bytes per row in the DRM dumb buffer
+    const int bpp    = 4; // BGRA / XRGB = 4 bytes per pixel
+
+    // The GL projection already maps Hyprland's y=0 (top of screen) to the
+    // bottom of the GL framebuffer, so glReadPixels row 0 corresponds to the
+    // top of the image — no Y-flip needed.
+    //
+    // We use raw glBindFramebuffer instead of m_framebuffer.bind() because
+    // the latter dereferences g_pHyprOpenGL->m_renderData.pMonitor for a
+    // viewport call, and that pointer has already been reset by endRender().
+    glBindFramebuffer(GL_READ_FRAMEBUFFER, m_framebuffer.m_fb);
+
+    if (stride == w * bpp) {
+        // Fast path: stride matches pixel width, single GL call for the
+        // entire framebuffer instead of one call per row.
+        glReadPixels(0, 0, w, h, GL_BGRA_EXT, GL_UNSIGNED_BYTE, pixelData);
+    } else {
+        // Stride differs from pixel width — read row by row.
+        for (int y = 0; y < h; ++y) {
+            uint8_t* dst = pixelData + y * stride;
+            glReadPixels(0, y, w, 1, GL_BGRA_EXT, GL_UNSIGNED_BYTE, dst);
+        }
+    }
+
+    glBindFramebuffer(GL_READ_FRAMEBUFFER, 0);
+
+    buf->endDataPtr();
+}
+
 bool CRenderbuffer::good() {
     return m_good;
 }
